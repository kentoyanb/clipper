@ 04,0 say '≥                            SUMMARY OF COLLECTION                             ≥'
@ 05,0 say '√ƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒ¥'
@ 06,0 say '≥ Term:                                                                        ≥'
@ 07,0 say '≥ From:                                                                        ≥'
@ 08,0 say '≥ To  :                                                                        ≥'
@ 09,0 say '≥ File:                                                                        ≥'
@ 10,0 say '≥                                                                              ≥'
@ 11,0 say '≥                                                                              ≥'
@ 12,0 say '≥                                                                              ≥'
@ 13,0 say '≥                                                                              ≥'
@ 14,0 say '≥                                                                              ≥'
@ 15,0 say '≥                                                                              ≥'
@ 16,0 say '≥                                                                              ≥'
@ 17,0 say '≥                                                                              ≥'
@ 18,0 say '≥                                                                              ≥'
@ 19,0 say '≥                                                                              ≥'
@ 20,0 say '√ƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒ¥'
@ 21,0 say '≥ Search Key :                                                                 ≥'
@ 22,0 say '√ƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒ¥'
@ 23,0 say '≥ ESC-EXIT    F3- Print Summary  F10 Change View Order                         ≥'
@ 24,0 say '¿ƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒƒŸ'
Return Nil


Function Ideal_file()
Local Retval
Local Counter := 0
 Do while counter <= 999
   If !File("F:\ARUNLIB\TEMP\CHRE"+padl(alltrim(str(counter)),3,"0")+".*")
      Retval := "CHRE"+padl(alltrim(str(counter)),3,"0")
      Exit
   Else
    Counter++
   Endif
 Enddo
Return Retval


Function Check_file(afile)
Local Retval := .F.

 If !file("F:\ARUNLIB\TEMP\"+afile+".*")
     Retval := .T.
   Else
   Alert("File already exist!",{"Cancel"})
    Retval  := .F.
 Endif
Return Retval


Function Gaugedisp(idxdbf,idxtag)
   Local aGauge
//   @ 08,06 TO 15,64  DOUBLE
//   @ 08,06 CLEAR TO 15,64
//   @ 09,10 Say "File Name :"+Upper(idxdbf)
//   @ 10,10 Say "Tag       :"+idxtag
//   @ 11,10 Say Replicate(Chr(219), 49)
   aGauge := GaugeNew( 12, 05, 14, 65, "GR+/GR", "GR+/GR")
   GaugeDisplay(aGauge)
   GaugeUpdate(agauge,recno()/Lastrec(),.T.)
Return Nil


Function chrepprint(term_desc,from_d,to_d)
Local Header1 := "University of Cebu in Lapulapu and Mandaue"
Local Header2 := "Cashier Department"
Local Header3 := "Summary of Collection from "+transform(from_d,"99-99-9999")+" to "+transform(to_d,"99-99-9999")
Local Page    := 1
Local Margin  := 5
Local oldpage := 0
Local counter := 1
Local line    := 8
Local choice
Local g_total := 0

  Do While .T.

   If !isprinter()
        inkey(1)
        Choice := Alert("Printer not ready or offline please check and try again!",{"Retry","Cancel"})
            If Choice == 2
               Exit
            Endif
   Endif

           Set Device to printer
           Set Printer On
           PrintStyle("line",2)
           PrintStyle("line",2)

  newdbf->(dbgotop())
  Do While !newdbf->(eof())

     If oldpage != page
        setprc(0,0)
         @ 01,155/2-len(Header1)/2 say Header1
         @ 02,155/2-len(Header2)/2 say Header2
         @ 03,155/2-len(Header3)/2 say Header3
         @ 04,01  say "Page # "+transform(page,"9999.")+"          "+term_desc+space(50)+"Date & Time Generated: "+DtoC(Date())+" : "+ampm(time())
         @ 05,01  say "----------------------------------------------------------------------------------------------------------------------------------------------------------------------"
         @ 06,01  say " SEQ. IDNO     STUDENT(S) NAME                 CTRG COURSE/YR        REFNO        PAY-DATE   TYPE    PAY-AMOUNT   PARTICULAR(S)                 CASHIER/TIME/STATION  "
         @ 07,01  say "----------------------------------------------------------------------------------------------------------------------------------------------------------------------"
         //            9999. 9999999  AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA  AAAA AAAAAAAAAAAAAA AAAAAAAAAAA 99-99-9999 AAAA  9,999,999.99   AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
         //            12345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567
         //                                                                                          Grand total   99,999,999.99
        oldpage := page
     Endif

         @ Line,03  say Ltrim(Transform(Counter,"9999."))
         @ Line,07  say newdbf->sm1idno
         @ Line,16  say PAD(newdbf->paynamto,30," ")
         @ Line,48  say newdbf->paycate
         @ Line,53  say display_course(newdbf->sm1idno,newdbf->sm1colcod,newdbf->sm1majcod,newdbf->sm1yrlvl)
         @ Line,70  say newdbf->payrefno
         @ Line,82  say Transform(newdbf->paydte,"99-99-9999")
         @ Line,93  say IF(newdbf->paytype == "0","CHECK","CASH")
         @ Line,99  say Transform(newdbf->payamt,"9,999,999.99")
         @ Line,114 say getpcd(newdbf->procode)
         @ Line,145 say newdbf->payentusr+transform(newdbf->payentime,"99999")+newdbf->payentws
           Line++
           Counter++
           g_total += newdbf->payamt
        

        If Line > 62
           @ Line,01  say "--------------------Continuing-Page--------------------Continuing-Page--------------------Continuing-Page-------------------Continuing-Page-----------------------"
           Eject
           Line := 8
           Page++
           Eject
        Endif

     skip+1
     loop
   Enddo

      IF  newdbf->(eof())
                  @ Line,01  say "--------------------Final-Page-Nothing--Follows-----------------------------------------Final-Page-Nothing--Follows-----------------------------------------------"
                    Line++
                    Line++
                  @ Line,79  say "================================================="
                    Line++
                  @ Line,79  say "Grand Total "
                  @ Line,99  say transform(g_total,"99,999,999.99")
                    Line++
                  @ Line,79  say "================================================="
              Eject
           Endif



   setprc(0,0)
   PrintStyle("line",66)
   Set Device To Screen
   Set Printer Off
   Exit
Enddo

Return Nil

/*------Function-header-ends-Here--------------------------------------------*/

Function getpcd(paycode)
Local oldalias := alias()
Local oldrec   := recno()
Local oldindex := ordbagname(indexord())
Local oldkey   := ordkey()
Local oldfocus := ordsetfocus()
Local retval
Local pycd     := "f:\arunlib\a999pycd.dbf"
Local pycdi    := "f:\arunlib\cdx\a999pycd.cdx"

dbusearea(.T.,"DBFCDX",pycd,"pycd",.T.,.F.)
dbsetindex(pycdi)
set order to tag py_code
pycd->(dbgotop())

   If pycd->(dbseek(trim(paycode))) == .T.
      retval :=  pycd->prodesc
   endif

pycd->(dbclosearea())

dbselectarea(oldalias)
ordsetfocus(oldfocus)
Return Retval


Function Display_Course(Idno,course,major,yr)
Local Retval   := space(13)
Local oldalias := alias()
Local oldrec   := recno()
Local oldindex := ordbagname(indexord())
Local oldkey   := ordkey()
Local oldfocus := ordsetfocus()
Local cour_1
Local cour_2
Local studstat := {}
Local llfound  := .F.

asize(studstat,15)

cour_1 := xget_cr(pad(course+major,3,' '))
cour_1 := cour_1+'-'+yr

llfound := xsearch_studno(Idno,studstat)
dbselectarea(oldalias)
ordsetfocus(oldfocus)




If llfound == .T.
//cour_2 := xget_cr(pad(studstat[05]+studstat[06],3,' '))
  cour_2 := studstat[05]+studstat[06]
cour_2 := cour_2+'-'+studstat[07]

   If cour_2 != cour_1
     retval := cour_1+'->'+cour_2
   Else
     retval := cour_2
   Endif
Endif

dbselectarea(oldalias)
ordsetfocus(oldfocus)

asize(studstat,0)
Return retval




