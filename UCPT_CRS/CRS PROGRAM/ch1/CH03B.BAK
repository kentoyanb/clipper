// Payment Routine For UCLM Elementary / High School (Student Account)
// For Cashier Program
// By. Edgar J. Esguerra
// Sept 3, 2002

# include "INKEY.CH"
# include "GRUMP.CH"
# include "GRUMPR.CH"
# include "GRUMPH.CH"
# include "GRUMPM.CH"
# include "SHADOWB.CH"
# include "DBINFO.CH"
# include "BOX.CH"
# include "SETCURS.CH"
# include "ac_ch.ch"
# include "dbstruct.ch"
# include "Getexit.ch"


 Function ch03b(Cashier_name)

//Save old settings

   Local oldscreen := savescreen(0,0,maxrow(),maxcol())
   Local oldcolor  := setcolor()
   Local oldcursor := setcursor()
//-----------------------------------------------------------------------------

//Local variables
   Local sch_term  := space(05)
   Local term_desc := space(40)
   Local pay_idno  := space(08)
   Local pay_date  := date() //ctod('  /  /  ')
   Local pay_type
   Local pay_chko  := space(20)
   Local pay_chkn  := space(20)
   Local pay_reci  := 0
   Local pay_amnt  := 0
   Local choice
   Local want
   Local counter := 0
   Local PROCODE  := "0001"
   Local OLDBALC  := "0071"
   Local acct_old := "N"
//-----------------------------------------------------------------------------

//Array variables

Local getlist         := {}  // getlist Array
Local term_stat       := {}  // Term Array
Local stud_stat       := {}  // Student Info Array
Local refno           := {}  // Refno Array
Local payment_details := {}  // Payment Information stat
Local specific_term   

//Set  environment settings
 SET( _SET_DECIMALS, 2)
 SET( _SET_CURSOR, SC_SPECIAL1)
 SET( _SET_DATEFORMAT, "MM-DD-YYYY")
 SET( _SET_ESCAPE, .T. )
 SET( _SET_CONFIRM, .T.)
 SET( _SET_COLOR ,"W+/B,W+/RB,,,GR+/B")
 //----------------------------------------------------------------------------


 //Initialized default working variables


Do While .t.
// if seconds() >= 57600.00     // 4:00 pm. system time
//     pay_date := date()+1
//  else
     pay_date := date()
//  endif

 pay_type := '1'
 acct_old := "N"
 PROCODE  := "0001"
 OLDBALC  := "0071"


 ScrB()
 @ 06,08 get sch_term picture "99999" when term_pre_valid(@sch_term) == .T. valid get_term(06,31,40,@sch_term,@term_desc,term_stat) == .T.
 @ 08,08 get pay_date picture "@!"    valid !empty(pay_date)
 @ 08,28 get acct_old picture "@!"    valid acct_old $ "N Y"
 @ 10,27 get pay_type picture "@!"    valid pay_type $ "0 1"
 @ 08,45 get pay_chko picture "@!"    when pay_type == "0" valid !empty(pay_chko)
 @ 10,45 get pay_chkn picture "@!"    when pay_type == "0" valid !empty(pay_chkn)
 @ 12,19 get pay_idno picture "@!"    when eIdno_pre_valid(@pay_idno) == .T.  valid eget_studno(@pay_idno,stud_stat) == .T.
 @ 14,58 get pay_reci picture "9,999,999.99" valid !empty(pay_reci)
 @ 15,58 get pay_amnt picture "9,999,999.99" valid !empty(pay_amnt)
 Read

    If Lastkey() == K_ESC
         Post_Valid_Dbf()
         Choice :=  Alert("Are you sure you want to exit?",{"Exit","Cancel"})
          If Choice == 1
             Choice := ""
             Exit
          Else
             Choice := ""
             loop
          Endif
    Endif


   @ 16,58 say Transform(pay_reci - pay_amnt,"9,999,999.99") Color ("GR+/B")

        want := Alert("Save & print official receipt?",{"Save","Cancel"})

        If want == 1

      // Get O.R. No and Display it
         Asize(refno,3)
         refno := Gen_payrefno(Cashier_name)
         @ 18,58 say refno[1]
         @ 20,40 say refno[2]

     //Determine payment purpose either for old balance or current account

        if acct_old == "Y"
           PROCODE  := OLDBALC
        Endif



        Asize(payment_details,21)

        //Determine Term Status
        //IF Payment Term Is 2 Semester in College
        //the Payment Term in High School & Elementary Still fall to First Semester

         

         if substr(sch_term,5,1) == "2"
              specific_term := val(sch_term)
            --specific_term
              specific_term := transform(specific_term,"99999")
           else
              specific_term := sch_term
         Endif


        //Assign Value to Payment Details

          payment_details[01] := refno[1]
          payment_details[02] := pay_date
          payment_details[03] := Val(strtran(time(),':','',1,len(time())))
          payment_details[04] := pay_type

     Do Case
        Case Empty(stud_stat[05])
          payment_details[05] := ""
        Case trim(stud_stat[05]) == 'E'
          payment_details[05] := "ELEM"
        Case trim(stud_stat[05]) == 'H'
          payment_details[05] := "HIGH"
        Case trim(stud_stat[05]) == 'K'
          payment_details[05] := "KIND"
     Endcase

          payment_details[06] := PROCODE
          payment_details[07] := pay_idno
          payment_details[08] := pay_amnt
          payment_details[09] := pay_chkn
          payment_details[10] := pay_chko
          payment_details[11] := trim(stud_stat[02])+' '+trim(stud_stat[03])+' '+trim(stud_stat[04])
          payment_details[12] := refno[3]
          payment_details[13] := refno[2]
          payment_details[14] := netname()
          payment_details[15] := 'E'+substr(specific_term,3,3)+'PAYP'
          payment_details[16] := stud_stat[5]
          payment_details[17] := stud_stat[6]
          payment_details[18] := stud_stat[7]
          payment_details[19] := get_pcd(PROCODE)
          payment_details[20] := 0
          payment_details[21] :=

       // Save to File

         SAVE2PAYM(sch_term,payment_details)
         eSAVE2PAYP(specific_term,payment_details)
         PRINTOR  (sch_term,payment_details)

     Endif



   // Flush the array variable and other variables
      Asize(term_stat,0)        // Array of Term Status
      Asize(stud_stat,0)        // Array of Student Status
      Asize(refno,0)            // Array of Refno Status
      Asize(payment_details,0)  // Array of Payment Information

        term_desc := space(40)
        pay_idno  := space(08)
        pay_chko  := space(20)
        pay_chkn  := space(20)
        pay_reci  := 0
        pay_amnt  := 0
        choice    := ""
        want      := ""
 Enddo

 // Destroy all variables

      Asize(term_stat,0)        // Array of Term Status
      Asize(stud_stat,0)        // Array of Student Status
      Asize(refno,0)            // Array of Refno Status
      Asize(payment_details,0)  // Array of Payment Information

        term_desc := space(40)
        pay_idno  := space(08)
        pay_type  := ''
        pay_date  := space(80)
        pay_chko  := space(20)
        pay_chkn  := space(20)
        pay_reci  := 0
        pay_amnt  := 0
        choice    := ""
        want      := ""


// Restore the old settings
restscreen(0,0,maxrow(),maxcol(),oldscreen)
SETCURSOR(oldcursor)
SETCOLOR(oldcolor)
Return Nil

//----------------------------------------------------------------------------

Function ScrB()
//----------------------------------------------------------------------------
         //  12345678901234567890123456789012345678901234567890123456789012345678901234567890
@ 01,0 say '┌──────────────────────────────────────────────────────────────────────────────┐'
@ 02,0 say '│                    University of Cebu in Lapulapu and Mandaue                │'
@ 03,0 say '│                       A.C Cortes Avenue, Mandaue City 6014                   │'
@ 04,0 say '│      PAYMENT ENTRIES ROUTINE FOR ELEMENTARY OR HIGH SCHOOL ACCOUNT BALANCE   │'
@ 05,0 say '├────────────────────────────┬─────────────────────────────────────────────────┤'
@ 06,0 say '│ Term:                      │                                                 │'
@ 07,0 say '├────────────────────────────┼─────────────────────────────────────────────────┤'
@ 08,0 say '│ Date:            Old Acct  │  Check Name :                                   │'
@ 09,0 say '├────────────────────────────┼─────────────────────────────────────────────────┤'
@ 10,0 say '│ Pay.Type 1-Cash 0-Check:   │  Check No.  :                                   │'
@ 11,0 say '├────────────────────────────┴───────┬─────────────────────────────────────────┤'
@ 12,0 say '│ Student Number :                   │       Payment Entries                   │'
@ 13,0 say '├────────────────────────────────────┼─────────────────────────────────────────┤'
@ 14,0 say '│ Name :                             │  Amount Recieved :                      │'
@ 15,0 say '│                                    │  Payment Amount  :                      │'
@ 16,0 say '│                                    │  Change          :                      │'
@ 17,0 say '├────────────────────────────────────┼─────────────────────────────────────────┤'
@ 18,0 say '│ School Level:                      │  O.R. NO.        :                      │'
@ 19,0 say '│ Year:                              ├─────────────────────────────────────────┤'
@ 20,0 say '│ Last Term Attended:                │                                         │'
@ 21,0 say '├────────────────────────────────────┼─────────────────────────────────────────┤'
@ 22,0 say '│ ESC - Exit  F4 - Prompt            │                                         │'
@ 23,0 say '│                                    │                                         │'
@ 24,0 say '└────────────────────────────────────┴─────────────────────────────────────────┘'
Return Nil



