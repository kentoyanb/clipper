
# include "ERROR.CH"
# include "TBROWSE.CH"
# include "INKEY.CH"
# include "SETCURS.CH"
# include "ord.ch"
# DEFINE  DEF_HSEP   "┬─"
# DEFINE  DEF_CSEP   "│"
# DEFINE  DEF_FSEP   "┴─"
# DEFINE  COL_COLOR "+W/B, +W/B, W+/BG, W+/BG, W+/G, 15/12, 15/12, N/W, N/W, W+/RB"
# DEFINE  TB_REFRESH_RATE 1


Function chmove()

 // Save old settings
 Local oldscreen := savescreen(0,0,maxrow(),maxcol())
 Local oldcolor  := setcolor()
 Local oldcursor := setcursor()
 Local sch_term  := space(05)
 Local term_stat := {}
 Local getlist   := {}
 Local term_desc := space(40)
 Local choice    := space(01)

// Set environment settings
SET( _SET_CURSOR, SC_SPECIAL1)
SET( _SET_DATEFORMAT, "MM-DD-YYYY")
SET( _SET_ESCAPE, .T. )
SET( _SET_CONFIRM, .T.)
SET( _SET_COLOR ,"W+/B,W+/RB,,,GR+/B")
savescreen(0,0,maxrow(),maxcol())

 Do while .T.

  movscr()


  @ 06,08 get sch_term   picture "99999" when term_pre_valid(@sch_term)   == .T. valid get_term(06,31,40,@sch_term,@term_desc,term_stat) == .T.
  read

     If Lastkey() == K_ESC
        Post_Valid_Dbf()
        Choice :=  Alert("Are you sure you want to exit?",{"Exit","Cancel"})
        If Choice == 1
            Exit
         Else
            loop
          Endif
    Endif

      move_or(sch_term)

   // Flush the array variable and other variables
      Asize(term_stat,0)        // Array of Term Status
      term_desc := space(40)
 Enddo

setcolor(oldcolor)
setcursor(oldcursor)
restscreen(0,0,maxrow(),maxcol(),oldscreen)
Return Nil

//----------------------------------------------------------------------------

 Function move_or(vterm)

 Local items  := {" Refno"," Paydate"," Lastname+Firstname+Middle"," Idno"," None"}
 Local paym  := "f:\arunlib\a"+substr(vterm,3,3)+"paym.dbf"
 Local paymi := "f:\arunlib\cdx\a"+substr(vterm,3,3)+"paym.cdx"
 Local oldcursor := setcursor(SC_NONE)
 Local Browse
 Local search_key      := ""
 Local B_COL           := 15
 Local Key_Counter     := 1
 Local Nrecno          := 0
 Local key             := 0
 Local Choice
 Local oldrecpos
 Local lowerscope := space(20)
 Local upperscope := space(20)
 Local paydetails := {}
 Local counter    := 0
 Local oldfocus
 Local payfile    := space(15)

 dbusearea(.T.,"DBFCDX",paym,"paym",.T.,.F.)
 paym->(ordlistadd(paymi))



 Browse           := TBrowseDB(06,1,20,78)
 Browse:headsep   := DEF_HSEP
 Browse:colsep    := DEF_CSEP
 Browse:footsep   := DEF_FSEP
 Browse:AddColumn(TBColumnNew("SEQ."         ,{ || transform(paym->(ordkeyno()),"9999.")}))
 Browse:AddColumn(TBColumnNew("REF-NO"       ,{ || paym->payrefno}))
 Browse:AddColumn(TBColumnNew("ID-NO"        ,{ || paym->sm1idno }))
 Browse:AddColumn(TBColumnNew("STUDENT-NAME" ,{ || pad(paym->paynamto,25,' ')}))
// Browse:AddColumn(TBColumnNew("CRS.   "    ,{ || xget_cr(pad(paym->sm1colcod+paym->sm1majcod,3,' ')) }))
 Browse:AddColumn(TBColumnNew("CRS.   "      ,{ || paym->sm1colcod+paym->sm1majcod }))
 Browse:AddColumn(TBColumnNew("YR"           ,{ || paym->sm1yrlvl}))
 Browse:AddColumn(TBColumnNew("AMOUNT"       ,{ || transform(paym->payamt,"999,999.99")}))
 Browse:AddColumn(TBColumnNew("TYPE"         ,{ || IF(paym->paytype == '1',"CASH ","CHECK")}))
 Browse:AddColumn(TBColumnNew("DATE"         ,{ || paym->paydte}))
 Browse:AddColumn(TBColumnNew("CASHIER"      ,{ || paym->payentusr}))
 Browse:Colpos := Browse:freeze
 Browse:Colorspec  := COL_COLOR


 Do While .T.

    Do While !browse:stabilize() .and. ( key := inkey() ) == 0
    Enddo

      If browse:Stable
         Browse:ColorRect({BROWSE:ROWPOS,1,Browse:ROWPOS,Browse:COLCOUNT},{3,4})
         Browse:Configure():RefreshAll()
         Key := inkey(0)
     Endif

  
   DO Case
      Case  key == K_F3
                   Browse:Forcestable()
                   oldrecpos := recno()
                   oldfocus  := ordsetfocus()
                   asize(paydetails,FCOUNT())
                   For Counter := 1 to FCOUNT()
                       paydetails[counter] := fieldget(counter)
                   Next

                   payfile := paydetails[15]
                   move_rec(vterm,paydetails,@payfile)
                   dbselectarea("paym")
                   paym->(dbsetindex(paymi))
                   ordsetfocus(oldfocus)
                   paym->(dbgoto(oldrecpos))
                     // Change the payfile signature
                      If alltrim(payfile) !=  alltrim(paydetails[15])
                         If !neterr()
                           do while !paym->(dbrlock()) .and. !neterr()
                           enddo
                          paym->payfile := payfile
                          paym->(dbunlock())
                         Endif
                     Endif
                   asize(paydetails,0)
                   payfile := space(15)
                   Browse:Forcestable():Refreshall()


      Case  key == K_F10
             Choice := pop_menu(17,40,22,70,items)

               Do Case
                  Case Choice == 1
                       Browse:Forcestable()
                         ordsetfocus("refno")
                         get_scope(@lowerscope,@upperscope)
                         set scope to lowerscope,upperscope
                         Browse:Forcestable():gotop():Refreshall()
                  Case Choice == 2
                       Browse:Forcestable()
                         ordsetfocus("Sdate")
                         get_scope(@lowerscope,@upperscope)
                         set scope to transform(lowerscope,"99-99-9999"),transform(upperscope,"99-99-9999")
                         Browse:Forcestable():gotop():Refreshall()
                  Case Choice == 3
                       Browse:Forcestable()
                         ordsetfocus("tname")
                         get_scope(@lowerscope,@upperscope)
                         set scope to lowerscope,upperscope
                         Browse:Forcestable():gotop():Refreshall()

                  Case Choice == 4
                      Browse:Forcestable()
                         ordsetfocus("tidno")
                         get_scope(@lowerscope,@upperscope)
                         set scope to lowerscope,upperscope
                         Browse:Forcestable():gotop():Refreshall()

                   Case Choice == 5
                      Browse:Forcestable()
                         set scope to
                         Browse:Forcestable():gotop():Refreshall()
               Endcase



      Case  Key == K_ESC
             paym->(dbclosearea())
             EXIT

      Case Key == K_DOWN
           Browse:down()
      Case Key == K_UP
           Browse:up()
      Case Key == K_PGDN
           Browse:pageDown()
      Case Key == K_PGUP
           Browse:pageUp()
      Case Key == K_CTRL_PGDN
           Browse:goBottom()
      Case Key == K_CTRL_PGUP
           Browse:goTop()
      Case Key == K_HOME
           Browse:home()
      Case Key == K_END
           Browse:end()
      Case Key == K_LEFT
           Browse:PanLeft()
      Case Key == K_RIGHT
           Browse:Panright()
      Case WAS_IN1(CHR(Key))  == .T.
             Search_key := Stuff(Search_key,key_counter,1,chr(Key))
               @ 21,B_COL say Upper(Chr(Key))
                 B_COL++
                 Key_counter++

               If paym->(dbseek(Upper(Search_key))) == .T.
                  nrecno := Recno()
                  Do while !browse:stabilize()
                  Enddo
                   If browse:stable
                      paym->(dbgoto(nrecno))
                      browse:Refreshall()
                   Endif
               Endif


      CASE Key == K_BS .And. Empty(Search_Key)
                     Key_Counter := 1
                     B_COL       := 15
                     Search_Key  := ""

      CASE Key == K_BS .And. !Empty(Search_key)

                     If Key_Counter <= 1
                         Key_Counter := 1
                         B_COL       := 15
                         Search_Key  := ""
                      Else
                        Key_Counter--
                        B_COL--
                     Endif

                    Search_key := Stuff(Search_Key,Key_counter,1,'')
                      @ 21,B_COL say " "

                   If paym->(dbseek(UPPER(Search_Key))) == .T.

                       nrecno := Recno()
                       Do while !browse:stabilize()
                       Enddo

                       If browse:stable
                          paym->(dbgoto(nrecno))
                          browse:refreshall()
                       Endif
                   Endif

  ENDCASE


// Reset B_COL, Search_key,Key_counter

    If Key == K_END  .or. key == K_HOME .or. key == K_UP .or. key == K_DOWN  .or.;
       Key == K_PGDN .or. key == K_PGUP .or. key == K_CTRL_PGUP .or. key == K_CTRL_PGDN

         B_COL          := 15
         @ 21,B_COL SAY SPACE(50)
         Search_key     := ""
         Key            := ""
         Key_counter    := 1
    Endif

 ENDDO





 setcursor(oldcursor)
 Return Nil

      


Function MOVSCR()
//----------------------------------------------------------------------------
         //  12345678901234567890123456789012345678901234567890123456789012345678901234567890
@ 01,0 say '┌──────────────────────────────────────────────────────────────────────────────┐'
@ 02,0 say '│                    University of Cebu in Lapulapu and Mandaue                │'
@ 03,0 say '│                       A.C Cortes Avenue, Mandaue City 6014                   │'
@ 04,0 say '│                            SUMMARY OF COLLECTION                             │'
@ 05,0 say '├──────────────────────────────────────────────────────────────────────────────┤'
@ 06,0 say '│ Term:                                                                        │'
@ 07,0 say '│                                                                              │'
@ 08,0 say '│                                                                              │'
@ 09,0 say '│                                                                              │'
@ 10,0 say '│                                                                              │'
@ 11,0 say '│                                                                              │'
@ 12,0 say '│                                                                              │'
@ 13,0 say '│                                                                              │'
@ 14,0 say '│                                                                              │'
@ 15,0 say '│                                                                              │'
@ 16,0 say '│                                                                              │'
@ 17,0 say '│                                                                              │'
@ 18,0 say '│                                                                              │'
@ 19,0 say '│                                                                              │'
@ 20,0 say '├──────────────────────────────────────────────────────────────────────────────┤'
@ 21,0 say '│ Search Key :                                                                 │'
@ 22,0 say '├──────────────────────────────────────────────────────────────────────────────┤'
@ 23,0 say '│ ESC-EXIT    F3- Move to Term  F10 Change View Order                          │'
@ 24,0 say '└──────────────────────────────────────────────────────────────────────────────┘'
Return Nil


 Function Get_scope(lower,upper)
 Local low  := space(20)
 Local high := space(20)
 Local getlist := {}
 Local oldscreen := savescreen(10,5,15,50)
 Local oldcursor := setcursor()
 SET( _SET_CURSOR, SC_SPECIAL1)


   @ 10,5 clear to 15,50
   @ 10,5 to 15,50 double

     @ 12,07 say "Lower Scope: "
     @ 13,07 say "Upper Scope: "
     @ 12,21 get low
     @ 13,21 get high
     Read

       lower := alltrim(low)
       upper := alltrim(high)

  setcursor(oldcursor)
  restscreen(10,5,15,50,oldscreen)
 Return Nil


  Function move_rec(vterm,paydetails,new_term)

     Local oldscr    := savescreen(05,10,10,75)
     Local oldcursor := setcursor()
     Local getlist   := {}
     Local counter   := 0
     Local sch_term  := space(05)
     Local details   := {}
     Local term_stat := {}
     Local term_desc := space(40)
     Local choice
     Local payp
     Local paypi
     Local xpayp
     Local xpaypi
     Local Flag      := .F.
     Local focus
     Local trans
     Local transi
     Local xtrans
     Local xtransi
     Local payo
     Local payoi


     @ 05,10 clear to 10, 75
     @ 05,10 to 10,75 double
     SET( _SET_CURSOR, SC_SPECIAL1)

      @ 07,12 Say "Move O.R. Number "+paydetails[1]
      @ 08,12 Say "To what term?  : "
      @ 09,12 Say "F4 - Prompt term "
      @ 08,29 get sch_term   picture "99999" when term_pre_valid(@sch_term)   == .T. valid get_term(08,35,40,@sch_term,@term_desc,term_stat) == .T.
  read
      Post_Valid_Dbf()

             

      Do Case
         // UCLM Files
         Case left(alltrim(UPPER(paydetails[15])),1) == "A" .and. substr(alltrim(UPPER(paydetails[15])),10,1) == "C"


              // Read Source dbf

               payp  := "f:\arunlib\a"+substr(vterm,3,3)+"payp.dbf"
               paypi := "f:\arunlib\cdx\a"+substr(vterm,3,3)+"payp.cdx"

               dbusearea(.T.,"DBFCDX",payp,"payp",.T.,.F.)
               payp->(ordlistadd(paypi))
               ordsetfocus("trefno")
               payp->(dbgotop())

               // Seek and get payment details
             If payp->(dbseek(alltrim(paydetails[1]))) == .T.
                      If payp->payposted == .T.
                          Flag := .F.
                          Alert("Posted Payment cannot be move!",{"Cancel"})
                       Else
                          Flag := .T.
                          asize(details,FCOUNT())
                          For Counter := 1 to Fcount()
                          details[counter] := fieldget(counter)
                          Next

                         do while !payp->(dbrlock()) .and. !neterr()
                         enddo
                         payp->(dbdelete())
                         payp->(dbunlock())
                     Endif
             Endif


            // Write to Target dbf

             xpayp  := "f:\arunlib\a"+substr(sch_term,3,3)+"payp.dbf"
             xpaypi := "f:\arunlib\cdx\a"+substr(sch_term,3,3)+"payp.cdx"

            // Check if file exist
          If !file(xpayp) .or. !file (xpaypi)
              // Recall if target file not exist
              do while !payp->(dbrlock()) .and. !neterr()
              enddo
              payp->(dbrecall())
              payp->(dbunlock())
              payp->(dbclosearea())
              Alert("Error! Target file not yet exist ",{"Cancel"})
              Flag := .F.
              new_term := ""
              asize(details,0)

             Else

                payp->(dbclosearea())
                payp   := xpayp
                paypi  := xpaypi
                xpayp  := ""
                xpaypi := ""

               dbusearea(.T.,"DBFCDX",payp,"payp",.T.,.F.)
               payp->(ordlistadd(paypi))
               ordsetfocus("trefno")
               payp->(dbgobottom())

               If  payp->(dbseek(alltrim(paydetails[1]))) == .T.
                   Alert(" O.R. number already exist !",{"Cancel"})
                   Flag := .F.
               Else

                  IF  Flag == .T.
                      payp->(dbappend())
                    If !neterr()
                      do while !payp->(dbrlock()) .and. !neterr()
                      enddo
                      For Counter := 1 to len(details)
                      fieldput(counter,details[counter])
                      Next
                      payp->(dbcommit())
                      payp->(dbunlock())
                    Endif
                     Flag := .F.
                     new_term := "a"+substr(sch_term,3,3)+"payp-c"
                     asize(details,0)
                     Alert("Record succesfully moved to target file.. ",{"OK"})
                  Endif
               ENDIF
                payp->(dbclosearea())
          Endif


         // METC FILES
         Case left(alltrim(UPPER(paydetails[15])),1) == "A" .and. substr(alltrim(UPPER(paydetails[15])),10,1) == "M"

              // Read Source dbf

               payp  := "f:\metc\arunlib\a"+substr(vterm,3,3)+"payp.dbf"
               paypi := "f:\metc\arunlib\a"+substr(vterm,3,3)+"payp.cdx"
               focus := "a"+substr(vterm,3,3)+"pay1"

               dbusearea(.T.,"DBFCDX",payp,"payp",.T.,.F.)
               ordlistadd(paypi)
               ordsetfocus(focus)
               payp->(dbgotop())

                   // Seek and get payment details

             If payp->(dbseek(alltrim(substr(paydetails[1],4,8)+dtos(paydetails[2])))) == .T.
                          Flag := .T.
                          asize(details,FCOUNT())
                          For Counter := 1 to Fcount()
                          details[counter] := fieldget(counter)
                          Next

                         do while !payp->(dbrlock()) .and. !neterr()
                         enddo
                         payp->(dbdelete())
                         payp->(dbunlock())
             Endif
                         focus := ""


            // Write to Target dbf

             xpayp  := "f:\metc\arunlib\a"+substr(sch_term,3,3)+"payp.dbf"
             xpaypi := "f:\metc\arunlib\a"+substr(sch_term,3,3)+"payp.cdx"

            // Check if file exist
          If !file(xpayp) .or. !file (xpaypi)
              // Recall Record if target file not exist
                  do while !payp->(dbrlock()) .and. !neterr()
                         enddo
                         payp->(dbrecall())
                         payp->(dbunlock())
                         payp->(dbclosearea())
              Alert("Error! Target file not yet exist ",{"Cancel"})
              Flag := .F.
              new_term := ""
              asize(details,0)
             Else

               payp->(dbclosearea())
               payp  := xpayp
               paypi := xpaypi
               focus := "a"+substr(sch_term,3,3)+"pay1"


               dbusearea(.T.,"DBFCDX",payp,"payp",.T.,.F.)
               ordlistadd(paypi)
               ordsetfocus(focus)
               payp->(dbgobottom())


               If payp->(dbseek(alltrim(substr(paydetails[1],4,8)+dtos(paydetails[2])))) == .T.
                  Alert(" O.R. number already exist !",{"Cancel"})
                  Flag := .F.
               Else

                  IF  Flag == .T.
                      payp->(dbappend())
                    If !neterr()
                      do while !payp->(dbrlock()) .and. !neterr()
                      enddo
                      For Counter := 1 to len(details)
                      fieldput(counter,details[counter])
                      Next
                      payp->(dbcommit())
                      payp->(dbunlock())
                    Endif
                     Flag := .F.
                     new_term := "a"+substr(sch_term,3,3)+"payp-m"
                     asize(details,0)
                     Alert("Record succesfully moved to target file.. ",{"OK"})
                  Endif
               ENDIF
                payp->(dbclosearea())
          Endif


         // ELEMENTARY & HIGH SCHOOL FILES
         Case left(alltrim(UPPER(paydetails[15])),1) == "E"
            
              // Read Source dbf

               payp  := "f:\erunlib\e"+substr(vterm,3,3)+"payp.dbf"
               paypi := "f:\erunlib\cdx\e"+substr(vterm,3,3)+"payp.cdx"

               dbusearea(.T.,"DBFCDX",payp,"payp",.T.,.F.)
               payp->(ordlistadd(paypi))
               ordsetfocus("trefno")
               payp->(dbgotop())

               // Seek and get payment details
             If payp->(dbseek(alltrim(paydetails[1]))) == .T.
                      If payp->payposted == .T.
                          Flag := .F.
                          Alert("Posted Payment cannot be move!",{"Cancel"})
                       Else
                          Flag := .T.
                          asize(details,FCOUNT())
                          For Counter := 1 to Fcount()
                          details[counter] := fieldget(counter)
                          Next

                         do while !payp->(dbrlock()) .and. !neterr()
                         enddo
                         payp->(dbdelete())
                         payp->(dbunlock())
                     Endif
             Endif
                         


            // Write to Target dbf

            xpayp  := "f:\erunlib\e"+substr(sch_term,3,3)+"payp.dbf"
            xpaypi := "f:\erunlib\cdx\e"+substr(sch_term,3,3)+"payp.cdx"

            // Check if file exist
          If !file(xpayp) .or. !file (xpaypi)
               // Recall if target file not exist
               do while !payp->(dbrlock()) .and. !neterr()
               enddo
               payp->(dbrecall())
               payp->(dbunlock())
               payp->(dbclosearea())
              Alert("Error! Target file not yet exist ",{"Cancel"})
              Flag := .F.
              new_term := ""
              asize(details,0)
             Else

               payp->(dbclosearea())
               payp  := xpayp
               paypi := xpaypi

               xpayp := ""
               xpaypi := ""

               dbusearea(.T.,"DBFCDX",payp,"payp",.T.,.F.)
               payp->(ordlistadd(paypi))
               ordsetfocus("trefno")
               payp->(dbgobottom())

               If  payp->(dbseek(alltrim(paydetails[1]))) == .T.
                   Alert(" O.R. number already exist !",{"Cancel"})
                   Flag := .F.
               Else

                  IF  Flag == .T.
                      payp->(dbappend())
                    If !neterr()
                      do while !payp->(dbrlock()) .and. !neterr()
                      enddo
                      For Counter := 1 to len(details)
                      fieldput(counter,details[counter])
                      Next
                      payp->(dbcommit())
                      payp->(dbunlock())
                    Endif
                     Flag := .F.
                     new_term := "e"+substr(sch_term,3,3)+"payp"
                     asize(details,0)
                     Alert("Record succesfully moved to target file.. ",{"OK"})
                  Endif
               ENDIF
                payp->(dbclosearea())
          Endif


         // SHORT TERM FILE
         Case substr(alltrim(UPPER(paydetails[15])),1,1) == "T"

              // Read Source dbf

               trans  := "f:\crunlib\short\tra"+vterm+".dbf"
               transi := "f:\crunlib\short\cdx\tra"+vterm+".cdx"

               dbusearea(.T.,"DBFCDX",trans,"trans",.T.,.F.)
               trans->(ordlistadd(transi))
               ordsetfocus("tnum")
               trans->(dbgotop())

               // Seek and get payment details
             If trans->(dbseek(alltrim(paydetails[1]))) == .T.
                 Flag := .T.
                 asize(details,FCOUNT())
                 For Counter := 1 to Fcount()
                 details[counter] := fieldget(counter)
                 Next

                  do while !trans->(dbrlock()) .and. !neterr()
                  enddo
                  trans->(dbdelete())
                  trans->(dbunlock())
              Endif
                         

            // Write to Target dbf

            xtrans  := "f:\crunlib\short\tra"+sch_term+".dbf"
            xtransi := "f:\crunlib\short\cdx\tra"+sch_term+".cdx"

            // Check if file exist
          If !file(xtrans) .or. !file (xtransi)
               // Recall if target file not exist
               do while !trans->(dbrlock()) .and. !neterr()
               enddo
               trans->(dbrecall())
               trans->(dbunlock())
               trans->(dbclosearea())
              Alert("Error! Target file not yet exist ",{"Cancel"})
              Flag := .F.
              new_term := ""
              asize(details,0)
             Else

               trans->(dbclosearea())
               trans  := xtrans
               transi := xtransi

               xtrans  := ""
               xtransi := ""

               dbusearea(.T.,"DBFCDX",trans,"trans",.T.,.F.)
               trans->(ordlistadd(transi))
               ordsetfocus("tnum")
               trans->(dbgobottom())

               If  trans->(dbseek(alltrim(paydetails[1]))) == .T.
                   Alert(" O.R. number already exist !",{"Cancel"})
                   Flag := .F.
                Else

                  IF  Flag == .T.
                      trans->(dbappend())
                    If !neterr()
                      do while !trans->(dbrlock()) .and. !neterr()
                      enddo
                      For Counter := 1 to len(details)
                      fieldput(counter,details[counter])
                      Next
                      trans->(dbcommit())
                      trans->(dbunlock())
                    Endif
                     Flag := .F.
                     new_term := "tra"+sch_term
                     asize(details,0)
                     Alert("Record succesfully moved to target file.. ",{"OK"})
                  Endif
               ENDIF
               trans->(dbclosearea())
           Endif


         // OTHER INCOME
         Case left(alltrim(UPPER(paydetails[15])),1) == "A" .and. substr(alltrim(UPPER(paydetails[15])),8,1) == "O"


              // Read Source dbf

               payo  := "f:\arunlib\a"+substr(vterm,3,3)+"payo.dbf"
               payoi := "f:\arunlib\cdx\a"+substr(vterm,3,3)+"payo.cdx"

               dbusearea(.T.,"DBFCDX",payo,"payo",.T.,.F.)
               payo->(ordlistadd(payoi))
               ordsetfocus("refno")
               payo->(dbgotop())

               // Seek and get payment details
             If payo->(dbseek(alltrim(paydetails[1]))) == .T.
                      Flag := .T.
                      asize(details,FCOUNT())
                      For Counter := 1 to Fcount()
                      details[counter] := fieldget(counter)
                      Next

                      do while !payo->(dbrlock()) .and. !neterr()
                      enddo
                      payo->(dbdelete())
                      payo->(dbunlock())
             Endif


            // Write to Target dbf

             xpayp  := "f:\arunlib\a"+substr(sch_term,3,3)+"payo.dbf"
             xpaypi := "f:\arunlib\cdx\a"+substr(sch_term,3,3)+"payo.cdx"

            // Check if file exist
          If !file(xpayp) .or. !file (xpaypi)
              // Recall if target file not exist
              do while !payo->(dbrlock()) .and. !neterr()
              enddo
              payo->(dbrecall())
              payo->(dbunlock())
              payo->(dbclosearea())
              Alert("Error! Target file not yet exist ",{"Cancel"})
              Flag := .F.
              new_term := ""
              asize(details,0)

             Else

                payo->(dbclosearea())
                payo   := xpayp
                payoi  := xpaypi
                xpayp  := ""
                xpaypi := ""

               dbusearea(.T.,"DBFCDX",payo,"payo",.T.,.F.)
               payo->(ordlistadd(payoi))
               ordsetfocus("refno")
               payo->(dbgobottom())

               If  payo->(dbseek(alltrim(paydetails[1]))) == .T.
                   Alert(" O.R. number already exist !",{"Cancel"})
                   Flag := .F.
               Else

                  IF  Flag == .T.
                      payo->(dbappend())
                    If !neterr()
                      do while !payo->(dbrlock()) .and. !neterr()
                      enddo
                      For Counter := 1 to len(details)
                      fieldput(counter,details[counter])
                      Next
                      payo->(dbcommit())
                      payo->(dbunlock())
                    Endif
                     Flag := .F.
                     new_term := "a"+substr(sch_term,3,3)+"payo"
                     asize(details,0)
                     Alert("Record succesfully moved to target file.. ",{"OK"})
                  Endif
               ENDIF
                payo->(dbclosearea())
          Endif

      Endcase


     setcursor(oldcursor)
     restscreen(05,10,10,75,oldscr)
  Return Nil





  


